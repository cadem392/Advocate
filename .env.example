# OpenAI API Key - server-side preferred
OPENAI_API_KEY=sk-your-key-here

# Optional: legacy client-side demo key path
NEXT_PUBLIC_OPENAI_API_KEY=

# Optional Python model inference service
MODEL_SERVICE_URL=http://localhost:8001

# Optional model artifacts directory for the inference service
MODEL_ARTIFACT_DIR=/absolute/path/to/model-artifacts

# Optional Hugging Face token for BlindSpot-style zero-shot inference
HF_TOKEN=
